{
  "name": "lume",
  "version": "3.2.0",
  "description": "A desktop application that tracks and visualizes time spent on tasks and applications",
  "main": "dist/main/main.js",
  "homepage": "./",
  "private": true,
  "scripts": {
    "start": "electron dist/main/main.js",
    "dev": "concurrently \"bun run dev:react\" \"bun run dev:electron\"",
    "dev:react": "bunx vite",
    "dev:electron": "bunx wait-on http://localhost:5173 && electron dist/main/main.js",
    "build": "bun run build:react && bun run build:electron && bun run build:mcp",
    "build:react": "bunx vite build",
    "build:electron": "bun build src/main/main.ts --outdir dist/main --target node --external electron --external better-sqlite3 --external @sentry/electron --external @sentry/electron/main && bun build src/main/preload.ts --outfile dist/preload.js --target browser --external electron",
    "build:mcp": "bun build src/mcp/server.ts --outdir dist/mcp/mcp --target node --external better-sqlite3 && cp src/mcp/package.json dist/mcp/mcp/package.json && chmod +x dist/mcp/mcp/server.js",
    "watch:electron": "bun build src/main/main.ts --outdir dist/main --target node --external electron --external better-sqlite3 --external @sentry/electron --external @sentry/electron/main --watch & bun build src/main/preload.ts --outfile dist/preload.js --target browser --external electron --watch",
    "dev:mcp": "bun run build:mcp && bun dist/mcp/mcp/server.js",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:e2e": "bunx playwright test",
    "test:e2e:ui": "bunx playwright test --ui",
    "test:e2e:headed": "bunx playwright test --headed",
    "test:e2e:debug": "bunx playwright test --debug",
    "test:e2e:report": "bunx playwright show-report",
    "lint": "bunx eslint src --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "bunx eslint src --ext .ts,.tsx,.js,.jsx --fix",
    "pack": "bunx electron-builder",
    "dist": "bun run build && bunx electron-builder"
  },
  "author": {
    "name": "Lume Team",
    "email": "team@lume.app"
  },
  "license": "MIT",
  "keywords": [
    "time tracking",
    "productivity",
    "desktop app",
    "electron",
    "react"
  ],
  "build": {
    "appId": "com.lume.app",
    "productName": "Lume",
    "win": {
      "icon": "src/public/logo1.png",
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "icon": "src/public/logo1.png",
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "icon": "src/public/logo1.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "files": [
      "dist/**/*",
      "src/public/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "dist/mcp/mcp",
        "to": "mcp"
      }
    ]
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@modelcontextprotocol/sdk": "^1.20.0",
    "@sentry/electron": "^7.2.0",
    "@tanstack/react-virtual": "^3.13.12",
    "better-sqlite3": "^12.4.1",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.23.24",
    "i18next": "^25.6.0",
    "i18next-browser-languagedetector": "^8.2.0",
    "lucide-react": "^0.545.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.65.0",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^16.0.1",
    "recharts": "^3.2.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.3.7",
    "@playwright/test": "^1.56.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/postcss": "^4.1.14",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "latest",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.45.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^38.2.1",
    "electron-builder": "^26.0.12",
    "eslint": "^9.37.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.14",
    "terser": "^5.37.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.10",
    "wait-on": "^8.0.5"
  }
}
